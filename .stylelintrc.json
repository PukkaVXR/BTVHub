{
  "extends": ["stylelint-config-standard"],
  "ignoreFiles": [
    "apps/hub/src/styles/foundation.css",
    "apps/hub/src/styles/workflows.css",
    "apps/hub/src/styles/stream-deck.css",
    "apps/hub/src/styles/live-and-tools.css",
    "apps/hub/src/styles/widgets.css",
    "apps/hub/src/styles/legacy-editor.css"
  ],
  "reportDescriptionlessDisables": true,
  "reportInvalidScopeDisables": true,
  "reportNeedlessDisables": true,
  "rules": {
    "color-no-hex": true,
    "declaration-block-no-duplicate-properties": true,
    "no-duplicate-selectors": true,
    "selector-class-pattern": null
  },
  "overrides": [
    {
      "files": ["apps/hub/src/styles/tokens.css"],
      "rules": {
        "color-no-hex": null
      }
    }
  ]
}
